# Choose the provider you want to use:
AI_PROVIDER=google

# Required API key for the chosen provider:
AI_API_KEY=your_api_key_here

# AI model to use (depends on the provider, e.g. "gemini-3.1-flash-lite" for Google Gemini):
AI_MODEL_ID=gemini-3.1-flash-lite

# Optional for custom endpoints like OpenRouter:
AI_BASE_URL=https://openrouter.ai/api/v1