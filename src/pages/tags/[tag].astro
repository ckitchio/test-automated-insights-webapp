---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

// 1. Generate a page for every unique tag
export async function getStaticPaths() {
	const allPosts = await getCollection('blog');

	// Extract all tags, flatten the array, and remove duplicates using a Set
	const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())];

	// Map through each tag to create the route and pass the matching posts
	return uniqueTags.map((tag) => {
		const filteredPosts = allPosts
			.filter((post) => post.data.tags?.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { tag },
			props: { posts: filteredPosts },
		};
	});
}

// 2. Grab the tag name and the filtered posts from the URL and Props
const { tag } = Astro.params;
const { posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`#${tag} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			/* We reuse the exact same layout from index.astro for consistency */
			main {
				width: 960px;
				max-width: 100%;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.tag-header {
				margin-bottom: 3rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.tag-header h1 {
				margin: 0;
			}
			.tag-header span {
				color: rgb(var(--accent));
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 3rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			li {
				display: flex;
				gap: 2rem;
				align-items: flex-start;
			}
			.image-container {
				flex-shrink: 0;
				width: 350px;
				border-radius: 8px;
				overflow: hidden;
				background-color: #eee;
				background-image: url('/default-hero.jpg');
				background-size: cover;
				background-position: center;
				aspect-ratio: 16 / 9;
				position: relative;
			}
			.image-container a {
				display: block;
    			width: 100%;
    			height: 100%;
			}
			.image-container img {
				width: 100%;
				height: 100%;
				border-radius: 8px;
				object-fit: cover;
				object-position: center;
				display: block;
			}
			.content-container {
				flex-grow: 1;
				display: flex;
				flex-direction: column;
			}
			.title {
				margin: 0 0 0.5rem 0;
				font-size: 2rem;
				line-height: 1.2;
			}
			.title a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.title a:hover {
				color: rgb(var(--accent));
			}
            .post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 0.8rem;
			}
			.tag-label {
				font-size: 0.85rem;
				padding: 0.2rem 0.6rem;
				background-color: rgb(var(--gray-light));
				color: rgb(var(--black));
				text-decoration: none;
				border-radius: 4px;
				transition: background-color 0.2s, color 0.2s;
			}
			.date {
				margin: 0 0 1.5rem 0;
				color: rgb(var(--gray));
			}
			.read-more {
				display: inline-block;
				background-color: rgb(var(--accent));
				color: black;
				text-decoration: none;
				border-radius: 4px;
				font-weight: bold;
				align-self: flex-start;
			}
			
			@media (max-width: 720px) {
				li {
					flex-direction: column;
					gap: 1rem;
				}
				.image-container {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="tag-header">
					<h1>Posts tagged with: <span>#{tag}</span></h1>
				</div>

				<ul>
					{
						posts.map((post) => (
							<li>
								<div class="image-container">
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image 
												width={720} 
												height={360} 
												src={post.data.heroImage} 
												alt={post.data.title} 
												onerror="this.style.opacity='0'"
											/>
										)}
									</a>
								</div>
								
								<div class="content-container">
									<h2 class="title">
										<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									</h2>
                                    {post.data.tags && post.data.tags.length > 0 && (
										<div class="post-tags">
											{post.data.tags.map((tag) => (
												<a href={`/tags/${tag}/`} class="tag-label">#{tag}</a>
											))}
										</div>
									)}
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<a class="read-more" href={`/blog/${post.id}/`}>Read More →</a>
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>